# Safe defaults for `npm run build` (no secrets). Copied to .env.production when that file is missing.
# Override locally in apps/web/.env.production (gitignored) if you point at a different PocketBase host.
#
# PocketBase is hosted off-Hostinger (option B). The frontend talks to it
# directly over HTTPS — no /hcgi/platform proxy on Hostinger anymore.
# CI overrides this via the VITE_POCKETBASE_URL GitHub secret (see .github/workflows).
VITE_POCKETBASE_URL=https://api.flowseekerlab.io
# Used when generating sitemap.xml / rss.xml in dist (canonical public origin).
SITE_URL=https://flowseekerlab.io
